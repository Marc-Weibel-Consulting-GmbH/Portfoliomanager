# Portfoliomanager — Environment-Vorlage
# Kopieren nach .env (.env ist gitignored) und Werte eintragen. KEINE echten Secrets hier committen.

# --- Pflicht (Server bootet sonst nicht) ---
DATABASE_URL=mysql://user:password@host:3306/portfoliomanager
JWT_SECRET=change-me-in-production
PORT=3000
NODE_ENV=development

# --- Secrets-Verschlüsselung (DB-gespeicherte API-Keys, A-09) ---
# Dedizierter 32-Byte-Schlüssel für AES-256-GCM, hex- oder base64-kodiert.
# Generieren mit: openssl rand -hex 32
# Fehlt der Key, fällt der Server (mit Warnung) auf die Legacy-Verschlüsselung
# via JWT_SECRET zurück; bestehende Werte werden beim ersten Lesen lazy auf
# das neue Format re-encryptet, sobald der Key gesetzt ist.
SECRETS_ENCRYPTION_KEY=

# --- Auth / OAuth ---
OAUTH_SERVER_URL=
OWNER_NAME=
OWNER_OPEN_ID=

# --- Marktdaten & Finanz-APIs ---
EODHD_API_KEY=
FINNHUB_API_KEY=
FINNHUB_WEBHOOK_SECRET=
FISCAL_API_KEY=
NEWSAPI_KEY=
TRADINGVIEW_MCP_URL=

# Financial-Datasets-MCP-Service (mcp-servers/financial-datasets auf Railway).
# Optional: ohne URL ist die Fundamentaldaten-Anreicherung (Copilot/Challenger,
# nur US-Titel) komplett inaktiv. Der Service selbst braucht FINANCIAL_DATASETS_API_KEY.
FINANCIAL_DATASETS_MCP_URL=

# --- Wikifolio (Trader-Suche & Portfolio-Import, F-15) ---
# Alternativ über die Admin-Secrets-Seite (DB) pflegbar; env hat Vorrang.
WIKIFOLIO_EMAIL=
WIKIFOLIO_PASSWORD=

# --- KI / LLM ---
BUILT_IN_FORGE_API_URL=
BUILT_IN_FORGE_API_KEY=

# --- Zahlung (Stripe) ---
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# --- E-Mail (Resend ODER SMTP) ---
RESEND_API_KEY=
EMAIL_FROM=
SMTP_HOST=
SMTP_PORT=
SMTP_SECURE=
SMTP_USER=
SMTP_PASS=
SMTP_FROM=

# --- WhatsApp / Twilio ---
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_WHATSAPP_NUMBER=

# --- Client (VITE_*, im Browser sichtbar — keine echten Secrets!) ---
VITE_APP_ID=
VITE_APP_TITLE="Portfoliomanager"
VITE_APP_URL=
VITE_APP_LOGO=
VITE_OAUTH_PORTAL_URL=
VITE_STRIPE_PUBLISHABLE_KEY=
VITE_TRUSTPILOT_BUSINESS_UNIT_ID=
VITE_WHATSAPP_NUMBER=
